// e-timologio — Phase 1 schema
// See README.md for context. All tenant-owned tables carry business_id.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────

enum BusinessRole {
  owner
  admin
  accountant
  staff
  sales
  readonly
}

// Platform-level role. Nullable on User: only staff of the SaaS itself carry a
// value here. Separate from BusinessRole (which is per-tenant membership).
enum PlatformRole {
  super_admin
  support
  analyst
}

enum AnnouncementTone {
  info
  warning
  success
}

model PlatformAnnouncement {
  id           String           @id @default(cuid())
  tone         AnnouncementTone @default(info)
  title        String           @db.VarChar(200)
  body         String           @db.Text
  ctaHref      String?          @db.VarChar(300)
  ctaLabel     String?          @db.VarChar(80)
  publishedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  authorId     String?

  author       User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([publishedAt])
  @@map("platform_announcements")
}

// ─── Payments ──────────────────────────────────────────────────────────

enum PaymentMethod {
  cash
  card
  bank_transfer
  iris
  check
  credit
  other
}

model Payment {
  id           String        @id @default(cuid())
  businessId   String
  clientId     String?
  documentId   String?
  amount       Decimal       @db.Decimal(12, 2)
  method       PaymentMethod @default(cash)
  reference    String?       @db.VarChar(160)
  notes        String?       @db.Text
  receivedAt   DateTime      @default(now())
  createdAt    DateTime      @default(now())

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  document     Document?     @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([businessId, receivedAt])
  @@index([documentId])
  @@index([clientId])
  @@map("payments")
}

// ─── Recurring documents ───────────────────────────────────────────────

enum RecurrenceCadence {
  weekly
  monthly
  quarterly
  yearly
}

enum RecurrenceStatus {
  active
  paused
  ended
}

model RecurringDocument {
  id             String            @id @default(cuid())
  businessId     String
  clientId       String
  billingBookId  String?
  branchId       String?
  type           DocumentType
  label          String            @db.VarChar(160)
  cadence        RecurrenceCadence @default(monthly)
  status         RecurrenceStatus  @default(active)
  nextRunAt      DateTime
  lastRunAt      DateTime?
  paymentMethod  String?           @db.VarChar(80)
  notes          String?           @db.Text
  // Snapshot of line template: itemId, description, qty, unit, unitPrice, discountPct, vatRate
  linesJson      String            @db.Text
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  business       Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client         Client            @relation(fields: [clientId], references: [id])
  billingBook    BillingBook?      @relation(fields: [billingBookId], references: [id], onDelete: SetNull)
  branch         Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([businessId, nextRunAt])
  @@index([status])
  @@map("recurring_documents")
}

model AppSetting {
  key         String   @id @db.VarChar(80)
  value       String   @db.Text
  description String?  @db.VarChar(255)
  updatedAt   DateTime @updatedAt

  @@map("app_settings")
}

// ─── Platform billing ───────────────────────────────────────────────────
// Represents what we sell to our customers (SaaS subscriptions). Kept
// separate from the tenant-facing "Business" invoicing surface — the platform
// admin is the seller here.

enum PlanBillingCycle {
  monthly
  yearly
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
}

enum PlatformInvoiceStatus {
  draft
  sending
  issued
  failed
  cancelled
}

model PlatformPlan {
  id                 String   @id @default(cuid())
  code               String   @unique @db.VarChar(40)
  name               String   @db.VarChar(120)
  description        String?  @db.VarChar(400)
  priceMonthly       Decimal  @default(0) @db.Decimal(12, 2)
  priceYearly        Decimal  @default(0) @db.Decimal(12, 2)
  includedDocsMonth  Int      @default(0)
  features           String?  @db.Text
  active             Boolean  @default(true)
  sortOrder          Int      @default(100)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subscriptions      BusinessSubscription[]

  @@map("platform_plans")
}

model BusinessSubscription {
  id                  String              @id @default(cuid())
  businessId          String
  planId              String
  billingCycle        PlanBillingCycle    @default(monthly)
  status              SubscriptionStatus  @default(active)
  priceOverride       Decimal?            @db.Decimal(12, 2)
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  nextBillingAt       DateTime?
  cancelledAt         DateTime?
  notes               String?             @db.Text
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  business            Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan                PlatformPlan        @relation(fields: [planId], references: [id])
  invoices            PlatformInvoice[]

  @@index([businessId])
  @@index([status])
  @@index([nextBillingAt])
  @@map("business_subscriptions")
}

// PlatformInvoice tracks invoices the platform issues to customers via Wrapp,
// with providerCost (what Wrapp charged us) and margin (what we net).
model PlatformInvoice {
  id                 String                @id @default(cuid())
  businessId         String
  subscriptionId     String?
  periodStart        DateTime?
  periodEnd          DateTime?
  status             PlatformInvoiceStatus @default(draft)
  series             String?               @db.VarChar(20)
  number             Int?
  issueDate          DateTime              @default(now())
  description        String                @db.VarChar(255)
  netAmount          Decimal               @default(0) @db.Decimal(12, 2)
  vatAmount          Decimal               @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal               @default(0) @db.Decimal(12, 2)
  providerCost       Decimal               @default(0) @db.Decimal(12, 2)
  providerRebate     Decimal               @default(0) @db.Decimal(12, 2)
  margin             Decimal               @default(0) @db.Decimal(12, 2)
  wrappInvoiceId     String?               @db.VarChar(120)
  wrappInvoiceUrl    String?               @db.VarChar(500)
  myDataMark         String?               @db.VarChar(80)
  myDataUid          String?               @db.VarChar(80)
  issuedAt           DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  business           Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  subscription       BusinessSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([status, issueDate])
  @@map("platform_invoices")
}

// Standalone log of provider (Wrapp) costs per business — used for margin
// reporting even when a cost isn't tied to a single invoice.
model ProviderCost {
  id            String   @id @default(cuid())
  businessId    String
  periodStart   DateTime
  periodEnd     DateTime
  netAmount     Decimal  @default(0) @db.Decimal(12, 2)
  vatAmount     Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal  @default(0) @db.Decimal(12, 2)
  description   String?  @db.VarChar(255)
  invoicedAt    DateTime?
  createdAt     DateTime @default(now())

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, periodStart])
  @@map("provider_costs")
}

enum WrappStatus {
  inactive
  pending
  active
  error
}

enum ItemKind {
  service
  product
}

enum DocumentType {
  invoice
  service_invoice
  retail_receipt
  service_receipt
  credit_note
  proforma
  quote
  order
  delivery_note
}

enum DocumentStatus {
  draft
  sending
  issued
  failed
  cancelled
}

enum PaymentStatus {
  unpaid
  partial
  paid
}

// ─── Users & Auth ───────────────────────────────────────────────────────

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  emailVerifiedAt DateTime?
  passwordHash   String?       @db.VarChar(255)
  fullName       String        @db.VarChar(120)
  mfaEnabled     Boolean       @default(false)
  mfaSecretEnc   String?       @db.Text
  mfaVerifiedAt  DateTime?
  platformRole   PlatformRole?
  suspendedAt    DateTime?
  suspendedReason String?      @db.VarChar(255)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  sessions       Session[]
  memberships    BusinessMember[]
  announcements  PlatformAnnouncement[]
  passwordResets PasswordReset[]
  emailVerifications EmailVerification[]
  oauthAccounts  OAuthAccount[]
  crmTasks       CrmTask[]
  notifications  Notification[]

  @@index([platformRole])
  @@map("users")
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique @db.VarChar(128)
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verifications")
}

enum NotificationTone {
  info
  success
  warning
  danger
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  businessId String?
  tone       NotificationTone @default(info)
  title      String           @db.VarChar(200)
  body       String?          @db.Text
  href       String?          @db.VarChar(400)
  entityType String?          @db.VarChar(60)
  entityId   String?          @db.VarChar(80)
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum OAuthProvider {
  google
  facebook
}

model OAuthAccount {
  id             String        @id @default(cuid())
  userId         String
  provider       OAuthProvider
  providerUserId String        @db.VarChar(191)
  email          String?       @db.VarChar(160)
  createdAt      DateTime      @default(now())

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model PasswordReset {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique @db.VarChar(128)
  expiresAt  DateTime
  usedAt     DateTime?
  ipAddress  String?   @db.VarChar(64)
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

model Session {
  id             String    @id @default(cuid())
  userId         String
  tokenHash      String    @unique @db.VarChar(128)
  activeBusinessId String?
  userAgent      String?   @db.VarChar(255)
  ipAddress      String?   @db.VarChar(64)
  expiresAt      DateTime
  createdAt      DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─── Businesses (tenants) ───────────────────────────────────────────────

model Business {
  id                String   @id @default(cuid())
  vatNumber         String   @db.VarChar(20)
  legalName         String   @db.VarChar(160)
  tradeName         String?  @db.VarChar(160)
  taxOffice         String?  @db.VarChar(120)
  activity          String?  @db.VarChar(200)
  addressLine       String?  @db.VarChar(200)
  city              String?  @db.VarChar(80)
  postalCode        String?  @db.VarChar(20)
  country           String   @default("GR") @db.VarChar(2)
  phone             String?  @db.VarChar(30)
  email             String?  @db.VarChar(160)
  // ΓΓΠΣ / AADE credentials for VAT (ΑΦΜ) lookup via the public reg webservice.
  // Encrypted at rest. Optional — presence unlocks real ΑΦΜ search from the app.
  aadeUsername      String?  @db.VarChar(120)
  aadePasswordEnc   String?  @db.Text
  aadeVerifiedAt    DateTime?
  suspendedAt       DateTime?
  suspendedReason   String?  @db.VarChar(255)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  members           BusinessMember[]
  wrappConnection   WrappConnection?
  clients           Client[]
  items             Item[]
  documents         Document[]
  auditLogs         AuditLog[]
  branches          Branch[]
  billingBooks      BillingBook[]
  subscriptions     BusinessSubscription[]
  platformInvoices  PlatformInvoice[]
  providerCosts     ProviderCost[]
  payments          Payment[]
  recurringDocs     RecurringDocument[]
  tags              Tag[]
  posTables         PosTable[]
  posTabs           PosTab[]
  leads             Lead[]
  opportunities     Opportunity[]
  crmTasks          CrmTask[]

  @@index([vatNumber])
  @@map("businesses")
}

model Branch {
  id           String   @id @default(cuid())
  businessId   String
  label        String   @db.VarChar(120)
  addressLine  String?  @db.VarChar(200)
  city         String?  @db.VarChar(80)
  postalCode   String?  @db.VarChar(20)
  phone        String?  @db.VarChar(30)
  isDefault    Boolean  @default(false)
  wrappBranchId String? @db.VarChar(120)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  billingBooks BillingBook[]
  documents    Document[]
  recurringDocs RecurringDocument[]

  @@index([businessId])
  @@map("branches")
}

model BillingBook {
  id             String       @id @default(cuid())
  businessId     String
  branchId       String?
  documentType   DocumentType
  series         String       @db.VarChar(20)
  label          String?      @db.VarChar(120)
  nextNumber     Int          @default(1)
  isDefault      Boolean      @default(false)
  wrappBookId    String?      @db.VarChar(120)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  business       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  documents      Document[]
  recurringDocs  RecurringDocument[]

  @@unique([businessId, documentType, series])
  @@index([businessId, documentType])
  @@map("billing_books")
}

model BusinessMember {
  id           String       @id @default(cuid())
  userId       String
  businessId   String
  role         BusinessRole @default(staff)
  createdAt    DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
  @@map("business_members")
}

model WrappConnection {
  id                 String      @id @default(cuid())
  businessId         String      @unique
  status             WrappStatus @default(inactive)
  wrappUserId        String?     @db.VarChar(120)
  hasPlan            Boolean     @default(false)
  canIssueInvoice    Boolean     @default(false)
  encryptedApiKey    String?     @db.Text
  jwtExpiresAt       DateTime?
  lastVerifiedAt     DateTime?
  lastError          String?     @db.Text
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  business           Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("wrapp_connections")
}

// ─── Audit log ──────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  businessId   String?
  userId       String?
  action       String   @db.VarChar(80)
  entityType   String?  @db.VarChar(60)
  entityId     String?  @db.VarChar(60)
  meta         String?  @db.Text
  ipAddress    String?  @db.VarChar(64)
  createdAt    DateTime @default(now())

  business     Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ─── Clients ────────────────────────────────────────────────────────────

model Client {
  id            String   @id @default(cuid())
  businessId    String
  vatNumber     String?  @db.VarChar(20)
  legalName     String   @db.VarChar(160)
  tradeName     String?  @db.VarChar(160)
  taxOffice     String?  @db.VarChar(120)
  activity      String?  @db.VarChar(200)
  addressLine   String?  @db.VarChar(200)
  city          String?  @db.VarChar(80)
  postalCode    String?  @db.VarChar(20)
  country       String   @default("GR") @db.VarChar(2)
  email         String?  @db.VarChar(160)
  phone         String?  @db.VarChar(30)
  notes         String?  @db.Text
  tags          String?  @db.VarChar(255)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contacts      ClientContact[]
  documents     Document[]
  payments      Payment[]
  recurringDocs RecurringDocument[]
  tagLinks      ClientTag[]

  @@index([businessId, legalName])
  @@index([businessId, vatNumber])
  @@map("clients")
}

model Tag {
  id         String   @id @default(cuid())
  businessId String
  label      String   @db.VarChar(60)
  color      String   @default("#334155") @db.VarChar(9)
  createdAt  DateTime @default(now())

  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clients    ClientTag[]

  @@unique([businessId, label])
  @@index([businessId])
  @@map("tags")
}

model ClientTag {
  clientId String
  tagId    String

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
  @@index([tagId])
  @@map("client_tags")
}

model ClientContact {
  id           String   @id @default(cuid())
  clientId     String
  name         String   @db.VarChar(120)
  email        String?  @db.VarChar(160)
  phone        String?  @db.VarChar(30)
  role         String?  @db.VarChar(80)

  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_contacts")
}

// ─── Items (services & products) ────────────────────────────────────────

model Item {
  id             String   @id @default(cuid())
  businessId     String
  kind           ItemKind @default(service)
  code           String?  @db.VarChar(60)
  name           String   @db.VarChar(160)
  description    String?  @db.Text
  unit           String   @default("τμχ") @db.VarChar(20)
  defaultPrice   Decimal  @default(0) @db.Decimal(12, 2)
  vatRate        Decimal  @default(24) @db.Decimal(5, 2)
  vatCategory    String?  @db.VarChar(20)
  active         Boolean  @default(true)
  // Inventory: null means not tracked; number is current on-hand quantity.
  stockOnHand    Decimal? @db.Decimal(14, 3)
  stockAlertAt   Decimal? @db.Decimal(14, 3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  documentLines  DocumentLine[]
  stockMovements StockMovement[]
  prices         ItemPrice[]

  @@index([businessId, kind])
  @@index([businessId, name])
  @@map("items")
}

enum StockMovementKind {
  in
  out
  adjustment
}

model StockMovement {
  id         String            @id @default(cuid())
  businessId String
  itemId     String
  kind       StockMovementKind
  quantity   Decimal           @db.Decimal(14, 3)
  reason     String?           @db.VarChar(200)
  documentId String?
  createdAt  DateTime          @default(now())

  item       Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([businessId, itemId])
  @@index([documentId])
  @@map("stock_movements")
}

model ItemPrice {
  id         String   @id @default(cuid())
  itemId     String
  tier       String   @db.VarChar(40)
  price      Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, tier])
  @@index([itemId])
  @@map("item_prices")
}

// ─── Documents (drafts only in Phase 1) ─────────────────────────────────

model Document {
  id                  String         @id @default(cuid())
  businessId          String
  clientId            String?
  branchId            String?
  billingBookId       String?
  type                DocumentType
  status              DocumentStatus @default(draft)
  paymentStatus       PaymentStatus  @default(unpaid)

  series              String?        @db.VarChar(20)
  number              Int?

  issueDate           DateTime       @default(now())
  deliveryNoteRef     String?        @db.VarChar(120)
  paymentMethod       String?        @db.VarChar(80)
  printLanguage       String         @default("el") @db.VarChar(2)
  additionalTaxes     String?        @db.Text
  notes               String?        @db.Text

  netTotalAmount      Decimal        @default(0) @db.Decimal(14, 2)
  vatTotalAmount      Decimal        @default(0) @db.Decimal(14, 2)
  totalAmount         Decimal        @default(0) @db.Decimal(14, 2)
  payableTotalAmount  Decimal        @default(0) @db.Decimal(14, 2)

  wrappInvoiceId      String?        @db.VarChar(120)
  wrappInvoiceUrl     String?        @db.VarChar(500)
  wrappInvoiceUrlEn   String?        @db.VarChar(500)
  myDataMark          String?        @db.VarChar(80)
  myDataUid           String?        @db.VarChar(80)
  myDataQrUrl         String?        @db.VarChar(500)
  lastWrappPayload    String?        @db.Text
  lastWrappError      String?        @db.Text
  issuedAt            DateTime?

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  business            Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client              Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  branch              Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  billingBook         BillingBook?   @relation(fields: [billingBookId], references: [id], onDelete: SetNull)
  lines               DocumentLine[]
  payments            Payment[]

  @@index([businessId, status])
  @@index([businessId, issueDate])
  @@index([businessId, clientId])
  @@map("documents")
}

model DocumentLine {
  id             String   @id @default(cuid())
  documentId     String
  itemId         String?
  ordinal        Int      @default(0)
  description    String   @db.VarChar(255)
  quantity       Decimal  @default(1) @db.Decimal(12, 3)
  unit           String   @default("τμχ") @db.VarChar(20)
  unitPrice      Decimal  @default(0) @db.Decimal(12, 2)
  discountPct    Decimal  @default(0) @db.Decimal(5, 2)
  vatRate        Decimal  @default(24) @db.Decimal(5, 2)
  netAmount      Decimal  @default(0) @db.Decimal(14, 2)
  vatAmount      Decimal  @default(0) @db.Decimal(14, 2)
  totalAmount    Decimal  @default(0) @db.Decimal(14, 2)

  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  item           Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@map("document_lines")
}

// ─── POS / Quick Sale ───────────────────────────────────────────────────

enum PosTabStatus {
  open
  closed
  cancelled
}

model PosTable {
  id         String   @id @default(cuid())
  businessId String
  label      String   @db.VarChar(60)
  seats      Int      @default(2)
  createdAt  DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tabs       PosTab[]

  @@unique([businessId, label])
  @@index([businessId])
  @@map("pos_tables")
}

model PosTab {
  id             String       @id @default(cuid())
  businessId     String
  tableId        String?
  label          String?      @db.VarChar(80)
  status         PosTabStatus @default(open)
  openedAt       DateTime     @default(now())
  closedAt       DateTime?
  documentId     String?      @db.VarChar(30)
  paymentMethod  String?      @db.VarChar(30)
  netTotal       Decimal      @default(0) @db.Decimal(12, 2)
  vatTotal       Decimal      @default(0) @db.Decimal(12, 2)
  total          Decimal      @default(0) @db.Decimal(12, 2)
  notes          String?      @db.Text

  business       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  table          PosTable?    @relation(fields: [tableId], references: [id], onDelete: SetNull)
  items          PosTabItem[]

  @@index([businessId, status])
  @@index([tableId])
  @@map("pos_tabs")
}

model PosTabItem {
  id          String   @id @default(cuid())
  tabId       String
  itemId      String?
  name        String   @db.VarChar(160)
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice   Decimal  @db.Decimal(12, 2)
  vatRate     Decimal  @default(24) @db.Decimal(5, 2)
  createdAt   DateTime @default(now())

  tab         PosTab   @relation(fields: [tabId], references: [id], onDelete: Cascade)

  @@index([tabId])
  @@map("pos_tab_items")
}

// ─── CRM ────────────────────────────────────────────────────────────────

enum LeadStatus {
  new
  contacted
  qualified
  disqualified
  converted
}

model Lead {
  id         String     @id @default(cuid())
  businessId String
  fullName   String     @db.VarChar(160)
  email      String?    @db.VarChar(160)
  phone      String?    @db.VarChar(40)
  company    String?    @db.VarChar(160)
  source     String?    @db.VarChar(80)
  status     LeadStatus @default(new)
  notes      String?    @db.Text
  clientId   String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]

  @@index([businessId, status])
  @@map("leads")
}

enum OpportunityStage {
  discovery
  proposal
  negotiation
  won
  lost
}

model Opportunity {
  id           String            @id @default(cuid())
  businessId   String
  leadId       String?
  clientId     String?
  title        String            @db.VarChar(200)
  stage        OpportunityStage  @default(discovery)
  amount       Decimal           @default(0) @db.Decimal(12, 2)
  probability  Int               @default(50)
  expectedCloseAt DateTime?
  notes        String?           @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lead         Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([businessId, stage])
  @@map("opportunities")
}

enum CrmTaskStatus {
  open
  done
  cancelled
}

model CrmTask {
  id           String        @id @default(cuid())
  businessId   String
  assigneeId   String?
  title        String        @db.VarChar(200)
  description  String?       @db.Text
  status       CrmTaskStatus @default(open)
  dueAt        DateTime?
  reminderAt   DateTime?
  leadId       String?
  clientId     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  assignee     User?         @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([businessId, status, dueAt])
  @@map("crm_tasks")
}
