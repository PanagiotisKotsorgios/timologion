# ─── Core ────────────────────────────────────────────────────────────────

# MySQL connection. Adjust user/password/host/db as needed.
DATABASE_URL="mysql://root:root@localhost:3306/etimologio"

# 32+ byte random string used to derive session token HMAC.
# Generate: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
SESSION_SECRET="change-me-to-a-long-random-string"

# Public base URL of the deployed app. Used for OAuth redirect URIs,
# password-reset links, email verification links, and sitemap/robots.
APP_BASE_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"

# ─── Wrapp (electronic-invoicing provider) ───────────────────────────────

WRAPP_API_BASE_URL="https://wrapp.ai/api/v1"
WRAPP_API_KEY=""

# ─── OAuth ────────────────────────────────────────────────────────────────
# Leave empty to disable the corresponding button on the login/register page.
# Redirect URIs to register on each provider dashboard:
#   Google:   ${APP_BASE_URL}/api/auth/google/callback
#   Facebook: ${APP_BASE_URL}/api/auth/fb/callback  (note: /fb/ not /facebook/)

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# ─── Email (Brevo transactional) ─────────────────────────────────────────
# Configured through the platform admin panel (persisted in AppSetting rows).
# BREVO_API_KEY is optional here; if provided, the app uses it as a fallback
# when the DB setting is unset.
BREVO_API_KEY=""

# ─── Cron / scheduled jobs ────────────────────────────────────────────────
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>` automatically.
# On self-hosted setups, the external caller must send the same header.
CRON_SECRET=""

# ─── Observability ───────────────────────────────────────────────────────
# Optional. When set, the logger forwards warn/error events to Sentry.
SENTRY_DSN=""
